{
  "name": "kidrooproject-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "set \"PATH=%PATH%;C:\\Windows\\System32;C:\\Windows\" && npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix kidrooBackend",
    "install-all": "npm install --prefix frontend && npm install --prefix kidrooBackend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "npm-run-all": "^4.1.5"
  }
}
